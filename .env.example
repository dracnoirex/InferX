# App Settings
APP_NAME=InferX
APP_VERSION=1.0.0
DEBUG=False
HOST=0.0.0.0
PORT=8000

# Model Settings
MODEL_NAME=distilbert-base-uncased
MAX_LENGTH=512
BATCH_SIZE=8
DEVICE=cuda

# Security — MUST change in production!
SECRET_KEY=change-this-to-a-random-secret-key-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin credentials — set via environment, never hardcode!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# HuggingFace
HF_TOKEN=your-huggingface-token-here


GRAFANA_PASSWORD=change-this-grafana-password